# ─── Database (PostgreSQL 16+ with pgvector) ───
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knowmesh

# ─── Redis (RQ broker) ───
REDIS_URL=redis://localhost:6379/0

# ─── S3-compatible object storage ───
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=knowmesh
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ─── LLM providers ───
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ─── Voyage AI (embeddings + reranking) ───
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-4-lite
VOYAGE_RERANK_MODEL=rerank-2.5-lite

# ─── Retrieval settings ───
RETRIEVAL_TOP_K=20
FINAL_TOP_K=5
VECTOR_SEARCH_WEIGHT=0.6
FTS_SEARCH_WEIGHT=0.25
GRAPH_SEARCH_WEIGHT=0.15

# ─── Upload limits ───
MAX_UPLOAD_SIZE_MB=50

# ─── CORS ───
CORS_ORIGINS=["http://localhost:5173","http://localhost"]
